ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Local: postgresql://localhost:5432/disco  (or postgresql://localhost/disco if default port)
# Docker: overridden automatically by compose.yml — do not change for Docker runs
DATABASE_URL=postgresql://localhost/disco

# Optional: comma-separated list of allowed frontend origins (defaults to http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000,https://your-deployed-frontend.com
